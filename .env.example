# Required: API key for The Odds API (https://the-odds-api.com)
ODDS_API_KEY=

# Required: API key for API-Sports (https://api-sports.io)
API_SPORTS_KEY=

# Required (agent only): API key for Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Docker: MCP server URL for agent (optional — defaults to Docker service name)
# MCP_SERVER_URL=http://server:8080

# OpenTelemetry (optional — defaults work for local dev with docker-compose)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACING_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_SAMPLING_PROBABILITY=1.0
OTEL_METRICS_STEP=30s
