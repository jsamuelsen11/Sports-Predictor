<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude Lombok-generated accessor patterns in JPA entity package only -->
    <Match>
        <Package name="com.sportspredictor.entity"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <!--
        Exclude mutable List exposure in record DTOs across the project.
        Java records with List fields inherently expose mutable state, but these are
        deserialized API responses and service DTOs that are effectively immutable in practice.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <!-- Exclude unread field warnings for @Spy fields in Mockito tests -->
    <Match>
        <Bug pattern="URF_UNREAD_FIELD"/>
        <Source name="~.*Test\.java"/>
    </Match>
</FindBugsFilter>
